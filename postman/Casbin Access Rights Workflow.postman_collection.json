    {
      "name": "[CLEANUP]",
      "item": [
        {
          "name": "1. Delete Budi",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/{{apiVersion}}/users/{{budiId}}",
              "host": ["{{baseURL}}"],
              "path": ["{{apiVersion}}", "users", "{{budiId}}"]
            }
          },
          "response": []
        },
        {
          "name": "1. Delete Endpoint",
          "request": {
